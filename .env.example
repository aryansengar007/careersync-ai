# Copy this file to .env.local and fill in your Firebase project credentials.
# Get these from: Firebase Console → Project Settings → General → Your apps → SDK setup.
# Until these are filled in, CareerSync AI runs on a local "Demo Auth" provider
# so you can develop and preview every feature without a live Firebase project.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
